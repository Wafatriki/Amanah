# ============================================
# AMANAH BACKEND - Variables de Entorno
# ============================================
# Copiar este archivo a .env y rellenar valores reales

# Node Environment
NODE_ENV=development

# Puerto del servidor (por defecto 3000)
PORT=3000

# Firebase Configuration
# Obtener de Firebase Console: Project Settings → Project ID
FIREBASE_PROJECT_ID=carely-app-8a882

# URL del frontend (para CORS - requerido en producción)
# Desarrollo: http://localhost:4200
# Producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:4200

# URL pública del backend (para generar URLs de descarga en respuestas)
# Desarrollo: http://localhost:3000
# Producción: https://api.tu-dominio.com
BACKEND_URL=http://localhost:3000
