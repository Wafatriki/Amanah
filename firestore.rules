rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Dependents - Allow all operations
    match /dependents/{dependentId} {
      allow create, read, write: if true;
      
      // Subcollections
      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // Tasks
    match /tasks/{taskId} {
      allow create, read, write: if true;
    }
    
    // Medications
    match /medications/{medicationId} {
      allow create, read, write: if true;
    }
    
    // Appointments
    match /appointments/{appointmentId} {
      allow create, read, write: if true;
    }
    
    // Chat Rooms
    match /chatRooms/{roomId} {
      allow create, read, write: if true;
    }
    
    // Users - Allow creating own profile
    match /users/{userId} {
      allow read: if true;
      allow create, write: if true;
    }
    
    // Invitations
    match /invitations/{invitationId} {
      allow create, read, write: if true;
    }
    
    // AI Chat Logs - Auditoría (solo crear)
    match /ai_chat_logs/{logId} {
      allow create, read, write: if true;
    }
    
    // Deny all by default
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
