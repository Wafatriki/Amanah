{
  "name": "amanah-functions",
  "description": "Cloud Functions for Amanah App",
  "version": "1.0.0",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "send:test": "node send_test_email.js",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@sendgrid/mail": "^8.1.6",
    "dotenv": "^17.4.2",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.0.0",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
